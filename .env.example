# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL publica do app — base dos links de confirmacao de e-mail (Supabase Auth) e do redirect /auth/callback.
# DEVE tambem constar na allow-list de Redirect URLs do Supabase (Auth -> URL Configuration), senao o
# Supabase ignora o emailRedirectTo e cai na Site URL.
#   Development: http://localhost:3000
#   Preview:     a URL de preview da Vercel (ex.: https://escritorio-digital-v2-git-<branch>-<escopo>.vercel.app)
#   Production:  https://escritorio-digital-v2.vercel.app   (ou dominio custom)
# Se ausente, o app cai na origem real da requisicao (funciona, mas configure explicitamente em producao).
NEXT_PUBLIC_SITE_URL=

# Anthropic (SuperAgent / IA)
ANTHROPIC_API_KEY=

# Secret compartilhado para o cron externo que dispara /api/agent/scheduler.
# O cron deve enviar este valor no header Authorization: Bearer <secret>
# (ou x-cron-secret: <secret>). Sem ele, a rota responde 401.
CRON_SECRET=

# Google Agenda — OAuth do usuário (sync de tarefas -> eventos + Google Meet real)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# (opcional) override do redirect; default = https://escritorio-digital-v2.vercel.app/api/google/oauth/callback
GOOGLE_OAUTH_REDIRECT_URI=
# Segredo p/ assinar o state do OAuth (CSRF). OBRIGATORIO em producao: a app LANCA se faltar.
# Use uma string aleatoria longa (ex.: openssl rand -hex 32).
OAUTH_STATE_SECRET=

# Google Agenda — conta de servico (fallback p/ quem NAO conectou OAuth; sem Meet)
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_CALENDAR_ID=
